# Backend Configuration

# Server
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/dtos_db?schema=public"

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# SMTP Configuration (for sending emails)
SMTP_HOST=gtxm1111.siteground.biz
SMTP_PORT=465
SMTP_USER=admin@dtgrowthpartners.com
SMTP_PASS=your-smtp-password

# Frontend URL (for invitation links)
FRONTEND_URL=https://os.dtgrowthpartners.com

# AI Chat Configuration
# Por defecto el chat usa DARIO (proxy local de la suscripción de Claude) en
# localhost:3456 con endpoints compatibles con OpenAI. No requiere créditos por token.
CHAT_AI_BASE_URL=http://localhost:3456/v1
CHAT_AI_API_KEY=dario
CHAT_AI_MODEL=claude-sonnet-4-6
# Modo de herramientas del chat (acceso al sistema):
#   off    = solo conversación, sin acceso al sistema. << default con DARIO >>
#            (DARIO = Claude Code, rechaza protocolos de tools como prompt injection)
#   native = function-calling nativo (tool_calls); requiere proveedor con tools
#            (p. ej. OpenRouter). Habilita consultar/crear/actualizar datos reales.
#   json   = protocolo acción-JSON sobre texto (solo modelos sin guardarraíles).
CHAT_TOOLS_MODE=off

# Legacy / fallback (OpenRouter) — usado solo si reconfiguras CHAT_AI_* a OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=moonshotai/kimi-k2

# Meta Ads (Graph API Direct)
META_ACCESS_TOKEN=your-meta-system-user-token